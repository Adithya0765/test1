{
  "version": 2,
  "framework": "node",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/careers", "destination": "/careers.html" },
    { "source": "/careers/apply", "destination": "/careers-apply.html" },
    { "source": "/registration", "destination": "/registration.html" },
    { "source": "/pre-register", "destination": "/registration.html" },
    { "source": "/pre-registration", "destination": "/registration.html" },
    { "source": "/forms/(.*)", "destination": "/forms.html" }
  ]
}
