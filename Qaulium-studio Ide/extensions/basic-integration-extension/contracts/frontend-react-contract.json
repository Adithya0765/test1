{
  "name": "qaulium.frontend.react.adapter",
  "version": "1.0.0",
  "purpose": "Defines the interface expected from a React host integration layer.",
  "eventsFromExtension": [
    {
      "event": "simulation:result",
      "payload": {
        "runId": "string",
        "backendId": "string",
        "metrics": "object",
        "observables": "object",
        "diagnostics": "array"
      }
    },
    {
      "event": "integration:health",
      "payload": {
        "frontendConnected": "boolean",
        "backendConnected": "boolean",
        "timestamp": "string"
      }
    }
  ],
  "methodsExpectedFromReactHost": [
    {
      "name": "mountPanel",
      "signature": "mountPanel(panelId: string, props: object): void"
    },
    {
      "name": "emitCommand",
      "signature": "emitCommand(commandId: string, payload?: object): Promise<void>"
    },
    {
      "name": "onStateUpdate",
      "signature": "onStateUpdate(callback: (state: object) => void): void"
    }
  ]
}
