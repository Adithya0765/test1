{
  "name": "qaulium.backend.cpp.adapter",
  "version": "1.0.0",
  "purpose": "Defines expected interface for a C++ simulation service bridge.",
  "transportOptions": ["rest", "grpc"],
  "rest": {
    "endpoint": "/simulate/basic",
    "method": "POST",
    "request": {
      "runId": "string",
      "circuit": "object",
      "config": "object"
    },
    "response": {
      "metrics": "object",
      "observables": "object",
      "diagnostics": "array"
    }
  },
  "grpc": {
    "service": "qaulium.simulation.BasicSimulator",
    "method": "Run",
    "requestMessage": "BasicRunRequest",
    "responseMessage": "BasicRunResult"
  },
  "nonFunctionalRequirements": {
    "timeoutMs": 10000,
    "idempotency": "runId",
    "errorShape": {
      "code": "string",
      "message": "string",
      "details": "object"
    }
  }
}
