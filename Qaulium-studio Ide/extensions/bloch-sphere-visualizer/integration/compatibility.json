{
    "extensionId":  "bloch-sphere-visualizer",
    "extensionDisplayName":  "Bloch Sphere Visualizer",
    "category":  "Visualization",
    "frontend":  {
                     "framework":  "react",
                     "entryPoint":  "integration/frontend-adapter.ts",
                     "panelId":  "blochSpherePanel",
                     "commands":  [
                                      "qaulium.visualization.bloch.open"
                                  ],
                     "eventsOut":  [
                                       "extension:ready",
                                       "view:mount",
                                       "simulation:result"
                                   ],
                     "eventsIn":  [
                                      "command:execute",
                                      "simulation:run",
                                      "state:update"
                                  ]
                 },
    "backend":  {
                    "language":  "c++",
                    "bridgeType":  "rest",
                    "endpoint":  "http://localhost:9000/simulate/bloch-sphere-visualizer",
                    "grpcService":  "qaulium.extensions.bloch.sphere.visualizer.Runner",
                    "required":  false,
                    "simulationBackends":  [

                                           ]
                }
}
