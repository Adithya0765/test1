{
  "name": "tensor-network-simulator",
  "displayName": "Tensor Network Simulator",
  "version": "1.0.0",
  "publisher": "qaulium",
  "activationEvents": [
    "onSimulation:tensor-network",
    "onCommand:qaulium.sim.tensor.run"
  ],
  "main": "index.js",
  "contributes": {
    "commands": [
      {
        "command": "qaulium.sim.tensor.run",
        "title": "Run Tensor Network Simulation"
      }
    ],
    "views": [
      {
        "id": "tensorMetricsView",
        "name": "Tensor Metrics",
        "location": "sidebar"
      }
    ],
    "simulationBackends": [
      {
        "id": "tensor-network",
        "label": "Tensor Network",
        "modes": ["wasm", "webgpu", "cloud"]
      }
    ]
  }
}
