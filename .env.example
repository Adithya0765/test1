# Qaulium AI - Server Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000

# SMTP Email Configuration (Titan Email)
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=admin@qauliumai.in
SMTP_PASS=Host@nirvana.in
SMTP_FROM="Qaulium AI" <admin@qauliumai.in>

# Where contact form submissions are emailed
CONTACT_EMAIL=admin@qauliumai.in

# Admin app (separate subdomain)
ADMIN_APP_ORIGIN=https://admin.qauliumai.in
ADMIN_LOGIN_EMAIL=admin@qauliumai.in
ADMIN_LOGIN_PASSWORD=change-this-strong-password
ADMIN_TOKEN_SECRET=change-this-long-random-secret